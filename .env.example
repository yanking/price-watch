# ==================== Docker Compose 配置 ====================

# 项目名称（用于容器命名前缀）
COMPOSE_PROJECT_NAME=price-watch

# ==================== 目录配置 ====================

# 数据目录
DATA_DIR=./docker/data
# 配置文件目录
CONFIG_DIR=./docker/config
# 日志目录
LOGS_DIR=./docker/logs

# ==================== MySQL ====================

MYSQL_VERSION=8.0
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=watch

# ==================== Redis ====================

REDIS_VERSION=7.4-alpine
REDIS_PORT=6379

# ==================== Jaeger ====================

JAEGER_VERSION=1.76.0
JAEGER_UI_PORT=16686

# ==================== OpenTelemetry Collector ====================

OTEL_COLLECTOR_VERSION=0.148.0
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318

# ==================== Prometheus ====================

PROMETHEUS_VERSION=v3.10.0
PROMETHEUS_PORT=9090

# ==================== Loki ====================

LOKI_VERSION=3.6.3
LOKI_PORT=3100

# ==================== Grafana ====================

GRAFANA_VERSION=12.4.1
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_PASSWORD=admin
